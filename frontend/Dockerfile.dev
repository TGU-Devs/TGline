
# ───────────────────────────────────────
# 1. ベースイメージ：Node.js 23
# ───────────────────────────────────────
FROM node:23

# ───────────────────────────────────────
# 2. 作業ディレクトリを設定
# ───────────────────────────────────────
WORKDIR /app

# ───────────────────────────────────────
# 3. パッケージをインストール
# ───────────────────────────────────────
COPY package.json ./
RUN npm install

# ───────────────────────────────────────
# 4. ポート宣言
# ───────────────────────────────────────
EXPOSE 3000