# ───────────────────────────────────────
# 1. ベースイメージ：Ruby 3.3.6
# ───────────────────────────────────────
FROM ruby:3.3.6

# ───────────────────────────────────────
# 2. システム依存パッケージをインストール
# ───────────────────────────────────────
RUN apt-get update -qq && \
    apt-get install -y nodejs build-essential postgresql-client
# ───────────────────────────────────────
# 3. 作業ディレクトリを設定
# ───────────────────────────────────────
WORKDIR /app

# 開発時はbind mountでホストのファイルをコンテナにマウントする形でいくからbundle installは不要
# コンテナ側でホストのコード(./backend:/app)し、bundle installを実行。設計的にホストのコードを正にする。gemなどの依存物はコンテナ管理で行いたいので!
# 理由: ホストでbundle installすると、イメージとボリュームが一致しなくなる問題がある
COPY Gemfile Gemfile.lock ./

# ───────────────────────────────────────
# 6. ポート宣言
# ───────────────────────────────────────
EXPOSE 3000

# ───────────────────────────────────────
# 7. 開発サーバー起動コマンド
# ───────────────────────────────────────
CMD ["bash", "-lc", "bundle exec rails db:create db:migrate && bundle exec rails server -b 0.0.0.0 -p 3000"]